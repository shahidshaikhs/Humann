{
  "type": "footer",
  "name": "t:names.footer",
  "sections": {
    "prefooter": {
      "type": "prefooter",
      "settings": {
        "color_scheme": "scheme-1",
        "padding-block-start": 72,
        "padding-block-end": 72
      }
    },
    "footer": {
      "type": "footer",
      "blocks": {
        "email_social_contact": {
          "type": "group",
          "settings": {
            "content_direction": "column",
            "vertical_on_mobile": true,
            "horizontal_alignment": "flex-start",
            "vertical_alignment": "center",
            "horizontal_alignment_flex_direction_column": "flex-start",
            "vertical_alignment_flex_direction_column": "flex-start",
            "gap": 8,
            "width": "fill",
            "width_mobile": "fill",
            "height": "fit",
            "inherit_color_scheme": true,
            "background_media": "none",
            "border": "none",
            "border_radius": 0,
            "padding-block-start": 0,
            "padding-block-end": 0,
            "padding-inline-start": 0,
            "padding-inline-end": 0
          },
          "blocks": {
            "signup_heading": {
              "type": "text",
              "settings": {
                "text": "<p><strong>Get 10% off when you sign up today.</strong></p>",
                "width": "100%",
                "alignment": "left",
                "type_preset": "custom",
                "font": "var(--font-body--family)",
                "font_size": "1.25rem",
                "line_height": "normal",
                "letter_spacing": "normal",
                "case": "none",
                "color": "var(--color-foreground)",
                "background": false,
                "padding-block-start": 0,
                "padding-block-end": 0,
                "padding-inline-start": 0,
                "padding-inline-end": 0
              }
            },
            "signup_subtitle": {
              "type": "text",
              "settings": {
                "text": "<p>Humann science in your inbox</p>",
                "width": "100%",
                "alignment": "left",
                "type_preset": "custom",
                "font": "var(--font-body--family)",
                "font_size": "1rem",
                "line_height": "normal",
                "letter_spacing": "normal",
                "case": "none",
                "color": "var(--color-foreground)",
                "background": false,
                "padding-block-start": 0,
                "padding-block-end": 0,
                "padding-inline-start": 0,
                "padding-inline-end": 0
              }
            },
            "email_signup": {
              "type": "email-signup",
              "settings": {
                "width": "fill",
                "inherit_color_scheme": true,
                "border_style": "none",
                "border_radius": 48,
                "input_type_preset": "paragraph",
                "style_class": "button-unstyled",
                "display_type": "arrow",
                "integrated_button": true,
                "padding-block-start": 0,
                "padding-block-end": 0,
                "padding-inline-start": 0,
                "padding-inline-end": 0
              }
            },
            "social_icons": {
              "type": "social-links",
              "settings": {
                "instagram_url": "https://www.instagram.com/gohumann",
                "twitter_url": "https://www.x.com/gohumann",
                "facebook_url": "https://www.facebook.com/gohumann"
              }
            },
            "contact_info": {
              "type": "text",
              "settings": {
                "text": "<p>1250 S Capital of Texas Highway<br>Austin, TX 78746</p><p>(855) 636-4040</p><p>info@humann.com</p>",
                "width": "100%",
                "alignment": "left",
                "type_preset": "custom",
                "font": "var(--font-body--family)",
                "font_size": "1rem",
                "line_height": "normal",
                "letter_spacing": "normal",
                "case": "none",
                "color": "var(--color-foreground)",
                "background": false,
                "padding-block-start": 0,
                "padding-block-end": 0,
                "padding-inline-start": 0,
                "padding-inline-end": 0
              }
            }
          },
          "block_order": [
            "signup_heading",
            "signup_subtitle",
            "email_signup",
            "social_icons",
            "contact_info"
          ]
        },
        "menu_shop": {
          "type": "menu",
          "settings": {
            "menu": "footer-shop",
            "heading": "Shop",
            "menu_spacing": 0,
            "show_as_accordion": true,
            "accordion_icon": "plus",
            "accordion_dividers": false,
            "inherit_color_scheme": true,
            "heading_preset": "paragraph",
            "link_preset": "paragraph",
            "padding-block-start": 0,
            "padding-block-end": 0,
            "padding-inline-start": 0,
            "padding-inline-end": 0
          }
        },
        "menu_learn": {
          "type": "menu",
          "settings": {
            "menu": "footer-learn",
            "heading": "Learn",
            "menu_spacing": 0,
            "show_as_accordion": true,
            "accordion_icon": "plus",
            "accordion_dividers": false,
            "inherit_color_scheme": true,
            "heading_preset": "paragraph",
            "link_preset": "paragraph",
            "padding-block-start": 0,
            "padding-block-end": 0,
            "padding-inline-start": 0,
            "padding-inline-end": 0
          }
        },
        "menu_support": {
          "type": "menu",
          "settings": {
            "menu": "footer-support",
            "heading": "Support",
            "menu_spacing": 0,
            "show_as_accordion": true,
            "accordion_icon": "plus",
            "accordion_dividers": false,
            "inherit_color_scheme": true,
            "heading_preset": "paragraph",
            "link_preset": "paragraph",
            "padding-block-start": 0,
            "padding-block-end": 0,
            "padding-inline-start": 0,
            "padding-inline-end": 0
          }
        },
        "bottom_content": {
          "type": "group",
          "settings": {
            "content_direction": "column",
            "horizontal_alignment_flex_direction_column": "flex-start",
            "vertical_alignment_flex_direction_column": "flex-start",
            "gap": 8,
            "width": "fill",
            "width_mobile": "fill",
            "height": "fit",
            "inherit_color_scheme": true,
            "background_media": "none",
            "border": "none",
            "border_radius": 0,
            "padding-block-start": 0,
            "padding-block-end": 0,
            "padding-inline-start": 0,
            "padding-inline-end": 0
          },
          "blocks": {
            "buttons_row": {
              "type": "group",
              "settings": {
                "content_direction": "row",
                "vertical_on_mobile": false,
                "horizontal_alignment": "flex-start",
                "vertical_alignment": "center",
                "gap": 8,
                "width": "fit-content",
                "width_mobile": "fit-content",
                "height": "fit",
                "inherit_color_scheme": true,
                "background_media": "none",
                "border": "none",
                "border_radius": 0,
                "padding-block-start": 0,
                "padding-block-end": 0,
                "padding-inline-start": 0,
                "padding-inline-end": 0
              },
              "blocks": {
                "btn_accessibility": {
                  "type": "button",
                  "settings": {
                    "label": "Accessibility",
                    "style_class": "button-secondary",
                    "width": "fit-content",
                    "width_mobile": "fit-content"
                  }
                },
                "btn_chat": {
                  "type": "button",
                  "settings": {
                    "label": "Chat",
                    "style_class": "button-secondary",
                    "width": "fit-content",
                    "width_mobile": "fit-content"
                  }
                }
              },
              "block_order": ["btn_accessibility", "btn_chat"]
            },
            "disclaimer_box": {
              "type": "group",
              "settings": {
                "content_direction": "column",
                "horizontal_alignment_flex_direction_column": "flex-start",
                "vertical_alignment_flex_direction_column": "flex-start",
                "gap": 8,
                "width": "fill",
                "width_mobile": "fill",
                "height": "fit",
                "inherit_color_scheme": true,
                "background_media": "none",
                "border": "solid",
                "border_width": 1,
                "border_opacity": 100,
                "border_radius": 4,
                "padding-block-start": 16,
                "padding-block-end": 16,
                "padding-inline-start": 16,
                "padding-inline-end": 16
              },
              "blocks": {
                "disclaimer_text": {
                  "type": "text",
                  "settings": {
                    "text": "<p>* According to IQVIA ProVoice Survey 2024</p><p>1 Based on the combination of all sales data for medical practitioners and professionals for humann products sold through pro.humann.com and medical sales distributor partners from 12/1/23 to 11/30/2024.</p><p>2 In a 16-week, double-blind, placebo-controlled study involving 119 healthy men and women, Heart Chews' polyphenol compound, taken as part of a healthy lifestyle was clinically shown nearly 2-times as effective at promoting normal blood pressure already in the normal range as a healthy lifestyle alone.</p><p>3 Based on Amazon 5-star ratings and reviews as of May 2024 for SuperBeets Heart Chews, Powder, Collagen, Energy Plus, Circulation Gummies, Energy Gummies, Beet Root Capsules, Sport, Memory + Focus.</p>",
                    "width": "100%",
                    "alignment": "left",
                    "type_preset": "custom",
                    "font": "var(--font-body--family)",
                    "font_size": "0.875rem",
                    "line_height": "normal",
                    "letter_spacing": "normal",
                    "case": "none",
                    "color": "var(--color-foreground)",
                    "background": false,
                    "padding-block-start": 0,
                    "padding-block-end": 0,
                    "padding-inline-start": 0,
                    "padding-inline-end": 0
                  }
                }
              },
              "block_order": ["disclaimer_text"]
            }
          },
          "block_order": ["buttons_row", "disclaimer_box"]
        }
      },
      "block_order": [
        "email_social_contact",
        "menu_shop",
        "menu_learn",
        "menu_support",
        "bottom_content"
      ],
      "settings": {
        "section_width": "page-width",
        "gap": 32,
        "color_scheme": "scheme-4",
        "padding-block-start": 40,
        "padding-block-end": 60
      }
    },
    "utilities": {
      "type": "footer-utilities",
      "settings": {
        "section_width": "page-width",
        "gap": 8,
        "divider_thickness": 0,
        "color_scheme": "scheme-4",
        "padding-block-start": 0,
        "padding-block-end": 16
      },
      "blocks": {
        "policy_list": {
          "type": "footer-policy-list",
          "settings": {
            "font_size": "0.875rem",
            "case": "none"
          }
        },
        "copyright": {
          "type": "footer-copyright",
          "settings": {
            "show_powered_by": false,
            "font_size": "0.875rem",
            "case": "none"
          }
        }
      },
      "block_order": [
        "policy_list",
        "copyright"
      ]
    }
  },
  "order": [
    "prefooter",
    "footer",
    "utilities"
  ]
}
