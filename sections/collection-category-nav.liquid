{%- liquid
  assign is_all_active = true
  for block in section.blocks
    if block.type == 'category' and block.settings.collection != blank
      if block.settings.collection.url == collection.url
        assign is_all_active = false
        break
      endif
    endif
  endfor
-%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--page-width spacing-style color-{{ section.settings.color_scheme }}"
  style="
    {% render 'spacing-style', settings: section.settings %}
    --pill-active-bg: {{ section.settings.active_bg_color }};
    --pill-active-text: {{ section.settings.active_text_color }};
    --pill-border-color: {{ section.settings.border_color }};
    --pill-text-color: {{ section.settings.text_color }};
  "
>
  <div class="category-nav">
    <div class="category-nav__mobile-bar">
      <span class="category-nav__count">{{ collection.products_count }} products</span>
      <button type="button" class="category-nav__filter-btn">Filter & Sort</button>
    </div>

    <div class="category-nav__row">
      {%- if section.settings.show_all_link -%}
        {%- liquid
          assign all_url = section.settings.all_link_url | default: '/collections/all'
        -%}
        <a
          href="{{ all_url }}"
          class="category-nav__pill{% if is_all_active %} category-nav__pill--active{% endif %}"
        >
          {%- if is_all_active -%}
            <svg class="category-nav__check" width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M3 8.5L6.5 12L13 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          {%- endif -%}
          {{ section.settings.all_link_text }}
        </a>
      {%- endif -%}

      {%- for block in section.blocks -%}
        {%- if block.type == 'category' -%}
          {%- liquid
            assign is_active = false
            if block.settings.collection != blank
              if block.settings.collection.url == collection.url
                assign is_active = true
              endif
            endif
            assign pill_label = block.settings.label
            if pill_label == blank and block.settings.collection != blank
              assign pill_label = block.settings.collection.title
            endif
          -%}
          <a
            href="{{ block.settings.collection.url | default: '#' }}"
            class="category-nav__pill{% if is_active %} category-nav__pill--active{% endif %}"
            {{ block.shopify_attributes }}
          >
            {%- if is_active -%}
              <svg class="category-nav__check" width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M3 8.5L6.5 12L13 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            {%- elsif block.settings.dot_color != blank -%}
              <span class="category-nav__dot" style="background-color: {{ block.settings.dot_color }};"></span>
            {%- endif -%}
            {{ pill_label }}
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>

<script type="module">
  document.querySelector('.category-nav__filter-btn')?.addEventListener('click', () => {
    document.querySelector('.facets-toggle__button')?.click();
  });
</script>

{% stylesheet %}
  .category-nav {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .category-nav__mobile-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-inline: 16px;
  }

  @media screen and (min-width: 750px) {
    .category-nav__mobile-bar {
      display: none;
    }
  }

  .category-nav__count {
    font-family: var(--font-body--family);
    font-weight: 500;
    font-size: 16px;
    line-height: 20px;
    letter-spacing: -0.5px;
    color: #767676;
  }

  .category-nav__filter-btn {
    background: none;
    border: none;
    padding: 8px 0;
    cursor: pointer;
    font-family: var(--font-body--family);
    font-weight: 500;
    font-size: 16px;
    line-height: 20px;
    letter-spacing: -0.5px;
    color: #414141;
  }

  .category-nav__row {
    display: flex;
    flex-direction: row;
    gap: 4px;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-inline: 4px;
  }

  .category-nav__row::-webkit-scrollbar {
    display: none;
  }

  .category-nav__pill {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    border-radius: 20px;
    padding: 8px 16px;
    border: 1px solid var(--pill-border-color);
    font-family: var(--font-subheading--family);
    font-weight: 700;
    font-size: 16px;
    line-height: 20px;
    white-space: nowrap;
    text-decoration: none;
    color: var(--pill-text-color);
    background-color: transparent;
    transition: background-color 0.2s, color 0.2s;
    cursor: pointer;
    flex-shrink: 0;
  }

  .category-nav__pill--active {
    background-color: var(--pill-active-bg);
    border-color: var(--pill-active-bg);
    color: var(--pill-active-text);
  }

  .category-nav__dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .category-nav__check {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  @media screen and (max-width: 749px) {
    .category-nav__pill {
      font-size: 14px;
      line-height: 18px;
    }

    .category-nav__row {
      padding-inline: 12px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Category Navigation",
  "class": "section-wrapper",
  "enabled_on": {
    "templates": ["collection"]
  },
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "color",
          "id": "dot_color",
          "label": "Dot color"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label override"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Shop All pill"
    },
    {
      "type": "checkbox",
      "id": "show_all_link",
      "label": "Show Shop All pill",
      "default": true
    },
    {
      "type": "text",
      "id": "all_link_text",
      "label": "Shop All text",
      "default": "Shop All"
    },
    {
      "type": "url",
      "id": "all_link_url",
      "label": "Shop All link"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "active_bg_color",
      "label": "Active background",
      "default": "#8C0132"
    },
    {
      "type": "color",
      "id": "active_text_color",
      "label": "Active text color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Pill border color",
      "default": "#D9D9DB"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Pill text color",
      "default": "#414141"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 12
    }
  ]
}
{% endschema %}
