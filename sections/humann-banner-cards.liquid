<div
  class="humann-banner-cards"
  style="
    --bg-color: {{ section.settings.background_color }};
    {% render 'spacing-style', settings: section.settings %}
  "
>
  <div class="humann-banner-cards__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="humann-banner-cards__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.subtitle != blank -%}
      <p class="humann-banner-cards__subtitle">{{ section.settings.subtitle }}</p>
    {%- endif -%}

    <hr class="humann-banner-cards__divider">

    <div class="humann-banner-cards__carousel">
      {%- for i in (1..3) -%}
        {%- liquid
          assign image_key = 'card_' | append: i | append: '_image'
          assign overlay_key = 'card_' | append: i | append: '_overlay_image'
          assign text_key = 'card_' | append: i | append: '_text'
          assign card_image = section.settings[image_key]
          assign card_overlay = section.settings[overlay_key]
          assign card_text = section.settings[text_key]
        -%}
        <div class="humann-banner-cards__card">
          {%- if card_image != blank -%}
            {{
              card_image
              | image_url: width: 800
              | image_tag:
                class: 'humann-banner-cards__card-bg',
                alt: '',
                loading: 'lazy',
                widths: '320,389,550,800',
                sizes: '(min-width: 750px) 389px, 82vw'
            }}
          {%- endif -%}

          {%- if card_overlay != blank -%}
            <div class="humann-banner-cards__card-overlay">
              {{
                card_overlay
                | image_url: width: 340
                | image_tag:
                  alt: '',
                  loading: 'lazy',
                  widths: '169,340',
                  sizes: '169px'
              }}
            </div>
          {%- endif -%}

          {%- if card_text != blank -%}
            <p class="humann-banner-cards__card-text">{{ card_text }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

    <div class="humann-banner-cards__cta-wrapper">
      {%- if section.settings.button_text != blank -%}
        <a
          class="humann-banner-cards__cta"
          {% if section.settings.button_url != blank %}href="{{ section.settings.button_url }}"{% endif %}
        >
          {{ section.settings.button_text }}
        </a>
      {%- endif -%}
    </div>
  </div>
</div>

{% stylesheet %}
  /* ===== Section wrapper ===== */
  .humann-banner-cards {
    background-color: var(--bg-color, #BC0F0F);
    padding-block-start: var(--padding-block-start, 80px);
    padding-block-end: var(--padding-block-end, 80px);
  }

  /* ===== Inner container ===== */
  .humann-banner-cards__inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  /* ===== Heading ===== */
  .humann-banner-cards__heading {
    font-family: 'Stabil Grotesk', var(--font-body--family), sans-serif;
    font-weight: 500;
    font-size: 48px;
    line-height: 52px;
    letter-spacing: 0;
    color: #FFFFFF;
    margin: 0;
  }

  .humann-banner-cards__heading strong {
    font-family: 'Moderat Serif', 'Moderat', var(--font-heading--family), serif;
    font-weight: 400;
    line-height: 36px;
    letter-spacing: -1px;
    display: block;
  }

  /* ===== Subtitle ===== */
  .humann-banner-cards__subtitle {
    font-family: 'Stabil Grotesk', var(--font-body--family), sans-serif;
    font-weight: 500;
    font-size: 20px;
    line-height: 24px;
    letter-spacing: 0;
    color: #FFFFFF;
    margin: 0;
  }

  .humann-banner-cards__subtitle strong {
    font-weight: 700;
  }

  /* ===== Divider ===== */
  .humann-banner-cards__divider {
    border: none;
    height: 1px;
    background: rgba(0, 0, 0, 0.3);
    margin: 0;
    width: 100%;
  }

  /* ===== Carousel ===== */
  .humann-banner-cards__carousel {
    display: flex;
    gap: 16px;
  }

  /* ===== Card ===== */
  .humann-banner-cards__card {
    position: relative;
    overflow: hidden;
    border-radius: 24px;
    display: flex;
    flex-direction: column;
    gap: 24px;
    justify-content: center;
    align-items: center;
    padding: 32px 24px;
    min-height: 480px;
    flex: 1;
  }

  .humann-banner-cards__card-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .humann-banner-cards__card-overlay {
    position: relative;
    z-index: 1;
    max-width: 169px;
  }

  .humann-banner-cards__card-overlay img {
    width: 100%;
    height: auto;
    display: block;
  }

  .humann-banner-cards__card-text {
    position: relative;
    z-index: 1;
    font-family: 'Moderat Serif', 'Moderat', var(--font-heading--family), serif;
    font-weight: 400;
    font-size: 28px;
    line-height: 32px;
    letter-spacing: -1px;
    text-align: center;
    color: #FFFFFF;
    margin: 0;
  }

  .humann-banner-cards__card-text strong {
    font-weight: 700;
  }

  /* ===== CTA Button ===== */
  .humann-banner-cards__cta-wrapper {
    display: flex;
    align-items: center;
    padding: 8px 0;
  }

  .humann-banner-cards__cta {
    display: inline-block;
    border: 2px solid #FFFFFF;
    border-radius: 28px;
    padding: 12px 20px;
    font-family: '(K) Uniforma', var(--font-body--family), sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 16px;
    letter-spacing: 0.75px;
    text-transform: uppercase;
    color: #FFFFFF;
    text-decoration: none;
  }

  /* ===== Mobile ===== */
  @media screen and (max-width: 749px) {
    .humann-banner-cards__inner {
      padding-inline: 16px;
      gap: 16px;
    }

    .humann-banner-cards__heading {
      line-height: 36px;
      letter-spacing: -1px;
    }

    .humann-banner-cards__subtitle {
      font-size: 18px;
      line-height: 20px;
    }

    .humann-banner-cards__carousel {
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
    }

    .humann-banner-cards__carousel::-webkit-scrollbar {
      display: none;
    }

    .humann-banner-cards__card {
      flex: 0 0 82vw;
      scroll-snap-align: start;
    }

    .humann-banner-cards__card-text {
      font-size: 24px;
      line-height: 28px;
    }

    .humann-banner-cards__cta {
      font-size: 14px;
      line-height: 14px;
    }
  }
{% endstylesheet %}

