{%- comment -%} Humann Prefooter — brand logo + tagline with inline product images {%- endcomment -%}
<div
  class="humann-prefooter"
  style="
    --prefooter-bg: {{ section.settings.background_color }};
    --prefooter-text-color: {{ section.settings.text_color }};
    --prefooter-border-color: {{ section.settings.border_color }};
    {% render 'spacing-style', settings: section.settings %}
  "
>
  <div class="humann-prefooter__inner">
    {%- comment -%} Logo {%- endcomment -%}
    <div class="humann-prefooter__logo">
      {%- if section.settings.logo_image != blank -%}
        {{ section.settings.logo_image | image_url: width: 560 | image_tag: alt: shop.name, loading: 'lazy', width: 280, height: 48 }}
      {%- else -%}
        <span class="humann-prefooter__logo-svg">
          {{ 'logo.svg' | inline_asset_content }}
        </span>
      {%- endif -%}
    </div>

    {%- comment -%} Tagline with inline product images {%- endcomment -%}
    <div class="humann-prefooter__tagline">
      {%- assign part1_words = section.settings.tagline_part1 | split: ' ' -%}
      {%- for word in part1_words -%}
        <span class="humann-prefooter__word humann-prefooter__word--serif">{{ word }}</span>
      {%- endfor -%}

      {%- if section.settings.chew_image != blank -%}
        <span class="humann-prefooter__inline-img humann-prefooter__inline-img--chew">
          {{ section.settings.chew_image | image_url: width: 56 | image_tag: loading: 'lazy', alt: '', width: 28, height: 21 }}
        </span>
      {%- endif -%}

      {%- assign part2_words = section.settings.tagline_part2 | split: ' ' -%}
      {%- for word in part2_words -%}
        <span class="humann-prefooter__word humann-prefooter__word--serif">{{ word }}</span>
      {%- endfor -%}

      {%- assign stat1_words = section.settings.tagline_stat1 | split: ' ' -%}
      {%- for word in stat1_words -%}
        <span class="humann-prefooter__word humann-prefooter__word--bold">{{ word }}</span>
      {%- endfor -%}

      {%- assign part3_words = section.settings.tagline_part3 | split: ' ' -%}
      {%- for word in part3_words -%}
        <span class="humann-prefooter__word humann-prefooter__word--serif">{{ word }}</span>
      {%- endfor -%}

      {%- if section.settings.capsule_image != blank -%}
        <span class="humann-prefooter__inline-img humann-prefooter__inline-img--capsule">
          {{ section.settings.capsule_image | image_url: width: 88 | image_tag: loading: 'lazy', alt: '', width: 44, height: 15 }}
        </span>
      {%- endif -%}

      {%- assign part4_words = section.settings.tagline_part4 | split: ' ' -%}
      {%- for word in part4_words -%}
        <span class="humann-prefooter__word humann-prefooter__word--serif">{{ word }}</span>
      {%- endfor -%}

      {%- if section.settings.gummie_image != blank -%}
        <span class="humann-prefooter__inline-img humann-prefooter__inline-img--gummie">
          {{ section.settings.gummie_image | image_url: width: 50 | image_tag: loading: 'lazy', alt: '', width: 23, height: 25 }}
        </span>
      {%- endif -%}

      {%- assign stat2_words = section.settings.tagline_stat2 | split: ' ' -%}
      {%- for word in stat2_words -%}
        <span class="humann-prefooter__word humann-prefooter__word--bold">{{ word }}</span>
      {%- endfor -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .humann-prefooter {
    background-color: var(--prefooter-bg, #FFFFFF);
    border: 1px solid var(--prefooter-border-color, #D9D9DB);
    padding-block-start: var(--padding-block-start, 72px);
    padding-block-end: var(--padding-block-end, 72px);
    padding-inline: 160px;
  }

  .humann-prefooter__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 48px;
    max-width: 780px;
    margin-inline: auto;
  }

  .humann-prefooter__logo {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .humann-prefooter__logo img {
    width: 280px;
    height: 48px;
  }

  .humann-prefooter__logo-svg svg {
    width: 280px;
    height: 48px;
  }

  .humann-prefooter__logo-svg svg,
  .humann-prefooter__logo-svg svg path {
    fill: var(--prefooter-text-color, #BC0F0F);
  }

  .humann-prefooter__tagline {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 3px;
  }

  .humann-prefooter__word {
    font-size: 28px;
    line-height: 32px;
    color: var(--prefooter-text-color, #BC0F0F);
  }

  .humann-prefooter__word--serif {
    font-family: 'Moderat Serif', var(--font-heading--family), serif;
    font-weight: 400;
    letter-spacing: -1px;
  }

  .humann-prefooter__word--bold {
    font-family: 'Stabil Grotesk', var(--font-body--family), sans-serif;
    font-weight: 700;
  }

  .humann-prefooter__inline-img {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .humann-prefooter__inline-img--chew {
    padding: 3px 4px 0 4px;
  }

  .humann-prefooter__inline-img--chew img {
    width: 28px;
    height: 21px;
  }

  .humann-prefooter__inline-img--capsule {
    padding: 8px 4px 0 4px;
  }

  .humann-prefooter__inline-img--capsule img {
    width: 44px;
    height: 15px;
    transform: rotate(1.6deg);
  }

  .humann-prefooter__inline-img--gummie {
    padding: 2px 2px 0 2px;
  }

  .humann-prefooter__inline-img--gummie img {
    width: 23px;
    height: 25px;
  }

  @media screen and (max-width: 749px) {
    .humann-prefooter {
      --padding-block-start: 60px;
      --padding-block-end: 60px;
      padding-inline: 20px;
    }

    .humann-prefooter__inner {
      gap: 60px;
    }

    .humann-prefooter__tagline {
      gap: 2px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Humann prefooter",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Logo image override",
      "info": "Leave empty to use the bundled SVG logo."
    },
    {
      "type": "header",
      "content": "Tagline"
    },
    {
      "type": "text",
      "id": "tagline_part1",
      "label": "Part 1 (serif)",
      "default": "A cardiovascular health company"
    },
    {
      "type": "text",
      "id": "tagline_part2",
      "label": "Part 2 (serif)",
      "default": "focused on the"
    },
    {
      "type": "text",
      "id": "tagline_stat1",
      "label": "Stat 1 (bold)",
      "default": "60,000 miles"
    },
    {
      "type": "text",
      "id": "tagline_part3",
      "label": "Part 3 (serif)",
      "default": "of your cardiovascular system"
    },
    {
      "type": "text",
      "id": "tagline_part4",
      "label": "Part 4 (serif)",
      "default": "fueling your"
    },
    {
      "type": "text",
      "id": "tagline_stat2",
      "label": "Stat 2 (bold)",
      "default": "36 trillion cells."
    },
    {
      "type": "header",
      "content": "Inline images"
    },
    {
      "type": "image_picker",
      "id": "chew_image",
      "label": "Chew image"
    },
    {
      "type": "image_picker",
      "id": "capsule_image",
      "label": "Capsule image"
    },
    {
      "type": "image_picker",
      "id": "gummie_image",
      "label": "Gummie image"
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#BC0F0F"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#D9D9DB"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 72
    }
  ],
  "presets": [
    {
      "name": "Humann prefooter"
    }
  ],
  "enabled_on": {
    "groups": ["footer"]
  }
}
{% endschema %}
