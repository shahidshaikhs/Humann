{%- liquid
  assign main_menu = section.settings.main_menu
  assign mega_trigger_text = section.settings.mega_trigger_text | default: 'Shop All'
-%}

<humann-header-component
  class="humann-header"
  data-section-id="{{ section.id }}"
  style="
    --header-bg: {{ section.settings.header_bg_color }};
    --header-text: {{ section.settings.header_text_color }};
    --header-border: {{ section.settings.header_border_color }};
    --cart-badge-bg: {{ section.settings.cart_badge_color }};
    {% render 'spacing-style', settings: section.settings %}
  "
>
  {%- comment -%} ===== DESKTOP + MOBILE HEADER BAR ===== {%- endcomment -%}
  <header class="humann-header__bar">
    <div class="humann-header__bar-inner">
      {%- comment -%} LEFT: Logo + Nav {%- endcomment -%}
      <div class="humann-header__left">
        <a href="{{ routes.root_url }}" class="humann-header__logo" aria-label="Home">
          {%- if section.settings.logo_image != blank -%}
            {{ section.settings.logo_image | image_url: width: 278 | image_tag: alt: shop.name, loading: 'eager', width: 139, height: 24 }}
          {%- else -%}
            <img
              src="{{ 'logo.svg' | asset_url }}"
              alt="{{ shop.name }}"
              width="139"
              height="24"
              style="width:139px;height:24px"
              loading="eager"
            >
          {%- endif -%}
        </a>

        <nav class="humann-header__nav" aria-label="Main navigation">
          <ul class="humann-header__nav-list">
            {%- comment -%} Mega-menu trigger {%- endcomment -%}
            <li class="humann-header__nav-item">
              <button
                class="humann-header__mega-trigger"
                data-mega-trigger
                aria-expanded="false"
                aria-controls="humann-mega-menu-{{ section.id }}"
                type="button"
              >
                <span>{{ mega_trigger_text }}</span>
                <img
                  src="{{ 'chevron-down-2.svg' | asset_url }}"
                  alt=""
                  width="24"
                  height="24"
                  class="humann-header__chevron-icon"
                  loading="eager"
                >
              </button>
            </li>

            {%- comment -%} Regular nav links from link_list {%- endcomment -%}
            {%- if main_menu != blank -%}
              {%- for link in linklists[main_menu].links -%}
                <li class="humann-header__nav-item">
                  <a href="{{ link.url }}" class="humann-header__nav-link">
                    {{ link.title }}
                  </a>
                </li>
              {%- endfor -%}
            {%- endif -%}
          </ul>
        </nav>
      </div>

      {%- comment -%} RIGHT: Icons {%- endcomment -%}
      <div class="humann-header__right">
        {%- comment -%} Search icon {%- endcomment -%}
        <a href="{{ routes.search_url }}" class="humann-header__icon" aria-label="Search">
          <img
            src="{{ 'search.svg' | asset_url }}"
            alt=""
            width="24"
            height="24"
            style="width:24px;height:24px"
            loading="eager"
          >
        </a>

        {%- comment -%} User icon + welcome text {%- endcomment -%}
        <a href="{{ routes.account_url }}" class="humann-header__icon humann-header__user-group" aria-label="Account">
          <img
            src="{{ 'user.svg' | asset_url }}"
            alt=""
            width="24"
            height="24"
            style="width:24px;height:24px"
            loading="eager"
          >
          {%- if customer -%}
            <span class="humann-header__welcome-text">Welcome, {{ customer.first_name }}!</span>
          {%- endif -%}
        </a>

        {%- comment -%} Cart icon with badge {%- endcomment -%}
        <a href="{{ routes.cart_url }}" class="humann-header__icon humann-header__cart-wrap" aria-label="Cart">
          <img
            src="{{ 'cart.svg' | asset_url }}"
            alt=""
            width="24"
            height="24"
            style="width:24px;height:24px"
            loading="eager"
          >
          <span class="humann-header__cart-badge" data-cart-badge style="display:none;">
            <span data-cart-count>0</span>
          </span>
        </a>

        {%- comment -%} Mobile hamburger {%- endcomment -%}
        <button
          class="humann-header__hamburger"
          data-drawer-open
          type="button"
          aria-label="Open menu"
          aria-expanded="false"
          aria-controls="humann-drawer-{{ section.id }}"
        >
          {{ 'icon-menu.svg' | inline_asset_content }}
        </button>
      </div>
    </div>
  </header>

  {%- comment -%} ===== DESKTOP MEGA-MENU ===== {%- endcomment -%}
  <div
    class="humann-header__mega-overlay"
    data-mega-overlay
    aria-hidden="true"
  ></div>
  <div
    class="humann-header__mega-menu"
    id="humann-mega-menu-{{ section.id }}"
    data-mega-menu
    aria-hidden="true"
  >
    <div class="humann-header__mega-inner">
      {%- comment -%} Column 1: Shop {%- endcomment -%}
      <div class="humann-header__mega-col">
        <p class="humann-header__mega-heading">{{ section.settings.mega_shop_heading }}</p>
        <ul class="humann-header__mega-links">
          {%- if section.settings.mega_shop_link_1_text != blank -%}
            <li>
              <a
                href="{{ section.settings.mega_shop_link_1_url | default: routes.all_products_collection_url }}"
                class="humann-header__mega-link"
              >
                {{ section.settings.mega_shop_link_1_text }}
              </a>
            </li>
          {%- endif -%}
          {%- if section.settings.mega_shop_link_2_text != blank -%}
            <li>
              <a
                href="{{ section.settings.mega_shop_link_2_url | default: '#' }}"
                class="humann-header__mega-link"
              >
                {{ section.settings.mega_shop_link_2_text }}
              </a>
            </li>
          {%- endif -%}
        </ul>
      </div>

      {%- comment -%} Column 2: Shop by Benefit {%- endcomment -%}
      <div class="humann-header__mega-col">
        <p class="humann-header__mega-heading">{{ section.settings.mega_benefit_heading }}</p>
        <ul class="humann-header__mega-benefits">
          {%- for i in (1..6) -%}
            {%- liquid
              assign text_key = 'mega_benefit_' | append: i | append: '_text'
              assign url_key = 'mega_benefit_' | append: i | append: '_url'
              assign color_key = 'mega_benefit_' | append: i | append: '_color'
              assign benefit_text = section.settings[text_key]
              assign benefit_url = section.settings[url_key]
              assign benefit_color = section.settings[color_key]
            -%}
            {%- if benefit_text != blank -%}
              <li class="humann-header__mega-benefit-item">
                <a
                  href="{{ benefit_url | default: '#' }}"
                  class="humann-header__mega-benefit-link"
                >
                  <span
                    class="humann-header__mega-benefit-dot{% if i == 6 %} humann-header__mega-benefit-dot--bordered{% endif %}"
                    style="background-color: {{ benefit_color }};"
                  ></span>
                  <span class="humann-header__mega-benefit-text">{{ benefit_text }}</span>
                </a>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </div>

      {%- comment -%} Column 3: Featured {%- endcomment -%}
      <div class="humann-header__mega-col humann-header__mega-col--featured">
        <p class="humann-header__mega-heading">{{ section.settings.mega_featured_heading }}</p>
        <div class="humann-header__mega-cards">
          {%- for i in (1..3) -%}
            {%- liquid
              assign img_key = 'mega_card_' | append: i | append: '_image'
              assign badge_key = 'mega_card_' | append: i | append: '_badge_text'
              assign desc_key = 'mega_card_' | append: i | append: '_description'
              assign url_key = 'mega_card_' | append: i | append: '_url'
              assign bg_key = 'mega_card_' | append: i | append: '_bg_color'
              assign card_image = section.settings[img_key]
              assign card_badge = section.settings[badge_key]
              assign card_desc = section.settings[desc_key]
              assign card_url = section.settings[url_key]
              assign card_bg = section.settings[bg_key]
            -%}
            {%- if card_image != blank or card_desc != blank -%}
              <a
                href="{{ card_url | default: '#' }}"
                class="humann-header__mega-card"
              >
                <div
                  class="humann-header__mega-card-img"
                  style="background-color: {{ card_bg | default: '#BC0F0F' }};"
                >
                  {%- if card_image != blank -%}
                    {{ card_image | image_url: width: 628 | image_tag: alt: card_desc, loading: 'lazy', class: 'humann-header__mega-card-photo' }}
                  {%- endif -%}
                  {%- if card_badge != blank -%}
                    <span class="humann-header__mega-card-badge">{{ card_badge }}</span>
                  {%- endif -%}
                </div>
                {%- if card_desc != blank -%}
                  <p class="humann-header__mega-card-desc">{{ card_desc }}</p>
                {%- endif -%}
              </a>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>

  {%- comment -%} ===== MOBILE DRAWER ===== {%- endcomment -%}
  <div
    class="humann-header__drawer-overlay"
    data-drawer-overlay
    aria-hidden="true"
  ></div>
  <div
    class="humann-header__drawer"
    id="humann-drawer-{{ section.id }}"
    data-drawer
    aria-hidden="true"
  >
    <div class="humann-header__drawer-top">
      {%- comment -%} Search input {%- endcomment -%}
      <form action="{{ routes.search_url }}" method="get" class="humann-header__drawer-search" role="search">
        <img
          src="{{ 'search.svg' | asset_url }}"
          alt=""
          width="20"
          height="20"
          class="humann-header__drawer-search-icon"
          loading="lazy"
        >
        <input
          type="search"
          name="q"
          class="humann-header__drawer-search-input"
          placeholder="Search products, articles, etc..."
          autocomplete="off"
        >
      </form>

      {%- comment -%} Close button {%- endcomment -%}
      <button
        class="humann-header__drawer-close"
        data-drawer-close
        type="button"
        aria-label="Close menu"
      >
        {{ 'icon-close.svg' | inline_asset_content }}
      </button>
    </div>

    {%- comment -%} Main nav {%- endcomment -%}
    <nav class="humann-header__drawer-nav" aria-label="Mobile navigation">
      <ul class="humann-header__drawer-nav-list">
        {%- comment -%} Shop by Benefit with expandable sub-items {%- endcomment -%}
        <li class="humann-header__drawer-nav-item">
          <button
            class="humann-header__drawer-nav-btn"
            data-benefit-toggle
            type="button"
            aria-expanded="false"
          >
            <span>{{ section.settings.mega_benefit_heading | default: 'Shop by Benefit' }}</span>
            <img
              src="{{ 'chevron-right.svg' | asset_url }}"
              alt=""
              width="24"
              height="24"
              class="humann-header__drawer-chevron"
              loading="lazy"
            >
          </button>
          <ul class="humann-header__drawer-sub" data-benefit-sub aria-hidden="true">
            {%- for i in (1..6) -%}
              {%- liquid
                assign text_key = 'mega_benefit_' | append: i | append: '_text'
                assign url_key = 'mega_benefit_' | append: i | append: '_url'
                assign color_key = 'mega_benefit_' | append: i | append: '_color'
                assign benefit_text = section.settings[text_key]
                assign benefit_url = section.settings[url_key]
                assign benefit_color = section.settings[color_key]
              -%}
              {%- if benefit_text != blank -%}
                <li class="humann-header__drawer-sub-item">
                  <a href="{{ benefit_url | default: '#' }}" class="humann-header__drawer-sub-link">
                    <span
                      class="humann-header__mega-benefit-dot{% if i == 6 %} humann-header__mega-benefit-dot--bordered{% endif %}"
                      style="background-color: {{ benefit_color }};"
                    ></span>
                    <span>{{ benefit_text }}</span>
                  </a>
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        </li>

        {%- comment -%} Shop SuperBeets {%- endcomment -%}
        {%- if section.settings.mega_shop_link_2_text != blank -%}
          <li class="humann-header__drawer-nav-item">
            <a href="{{ section.settings.mega_shop_link_2_url | default: '#' }}" class="humann-header__drawer-nav-link">
              {{ section.settings.mega_shop_link_2_text }}
            </a>
          </li>
        {%- endif -%}

        {%- comment -%} Shop All {%- endcomment -%}
        {%- if section.settings.mega_shop_link_1_text != blank -%}
          <li class="humann-header__drawer-nav-item">
            <a href="{{ section.settings.mega_shop_link_1_url | default: routes.all_products_collection_url }}" class="humann-header__drawer-nav-link">
              {{ section.settings.mega_shop_link_1_text }}
            </a>
          </li>
        {%- endif -%}

        {%- comment -%} Regular menu links {%- endcomment -%}
        {%- if main_menu != blank -%}
          {%- for link in linklists[main_menu].links -%}
            <li class="humann-header__drawer-nav-item">
              <a href="{{ link.url }}" class="humann-header__drawer-nav-link">
                {{ link.title }}
              </a>
            </li>
          {%- endfor -%}
        {%- endif -%}
      </ul>
    </nav>

    <hr class="humann-header__drawer-divider">

    {%- comment -%} Featured promo cards {%- endcomment -%}
    <div class="humann-header__drawer-featured">
      <p class="humann-header__drawer-featured-heading">{{ section.settings.mega_featured_heading | default: 'Featured' }}</p>
      <div class="humann-header__drawer-cards">
        {%- for i in (1..3) -%}
          {%- liquid
            assign img_key = 'mega_card_' | append: i | append: '_image'
            assign badge_key = 'mega_card_' | append: i | append: '_badge_text'
            assign desc_key = 'mega_card_' | append: i | append: '_description'
            assign url_key = 'mega_card_' | append: i | append: '_url'
            assign bg_key = 'mega_card_' | append: i | append: '_bg_color'
            assign card_image = section.settings[img_key]
            assign card_badge = section.settings[badge_key]
            assign card_desc = section.settings[desc_key]
            assign card_url = section.settings[url_key]
            assign card_bg = section.settings[bg_key]
          -%}
          {%- if card_image != blank or card_desc != blank -%}
            <a
              href="{{ card_url | default: '#' }}"
              class="humann-header__drawer-card"
            >
              <div
                class="humann-header__drawer-card-img"
                style="background-color: {{ card_bg | default: '#BC0F0F' }};"
              >
                {%- if card_image != blank -%}
                  {{ card_image | image_url: width: 508 | image_tag: alt: card_desc, loading: 'lazy', class: 'humann-header__drawer-card-photo' }}
                {%- endif -%}
                {%- if card_badge != blank -%}
                  <span class="humann-header__drawer-card-badge">{{ card_badge }}</span>
                {%- endif -%}
              </div>
              {%- if card_desc != blank -%}
                <p class="humann-header__drawer-card-desc">{{ card_desc }}</p>
              {%- endif -%}
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    <hr class="humann-header__drawer-divider">

    {%- comment -%} Secondary links {%- endcomment -%}
    <div class="humann-header__drawer-secondary">
      {%- if section.settings.pro_heading != blank -%}
        <div class="humann-header__drawer-pro">
          <a
            href="{{ section.settings.pro_url | default: '#' }}"
            class="humann-header__drawer-pro-title"
          >
            {{ section.settings.pro_heading }}
          </a>
          {%- if section.settings.pro_description != blank -%}
            <p class="humann-header__drawer-pro-desc">{{ section.settings.pro_description }}</p>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if section.settings.secondary_menu != blank -%}
        <ul class="humann-header__drawer-secondary-list">
          {%- for link in linklists[section.settings.secondary_menu].links -%}
            <li>
              <a href="{{ link.url }}" class="humann-header__drawer-secondary-link">
                {{ link.title }}
              </a>
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>
  </div>
</humann-header-component>

{% stylesheet %}
  /* ===== HEADER BAR ===== */
  .humann-header {
    display: block;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .humann-header__bar {
    background-color: var(--header-bg, #FFFFFF);
    border-bottom: 1px solid var(--header-border, #A0A0A0);
    height: 64px;
  }

  .humann-header__bar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    padding: 0 24px;
    max-width: 1440px;
    margin: 0 auto;
  }

  /* Left zone: logo + nav */
  .humann-header__left {
    display: flex;
    align-items: center;
    gap: 36px;
  }

  .humann-header__logo {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    line-height: 0;
  }

  .humann-header__logo img {
    width: 139px;
    height: 24px;
    object-fit: contain;
  }

  /* Nav */
  .humann-header__nav {
    display: none;
  }

  @media screen and (min-width: 750px) {
    .humann-header__nav {
      display: block;
    }
  }

  .humann-header__nav-list {
    display: flex;
    align-items: center;
    gap: 20px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .humann-header__nav-link {
    font-family: 'Stabil Grotesk', var(--font-body--family), sans-serif;
    font-weight: 500;
    font-size: 16px;
    line-height: 20px;
    color: var(--header-text, #414141);
    text-decoration: none;
    white-space: nowrap;
  }

  .humann-header__nav-link:hover {
    opacity: 0.7;
  }

  /* Mega-menu trigger */
  .humann-header__mega-trigger {
    display: flex;
    align-items: center;
    gap: 8px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    font-family: 'Stabil Grotesk', var(--font-body--family), sans-serif;
    font-weight: 700;
    font-size: 16px;
    line-height: 20px;
    color: var(--header-text, #414141);
    white-space: nowrap;
  }

  .humann-header__mega-trigger:hover {
    opacity: 0.7;
  }

  .humann-header__chevron-icon {
    width: 24px;
    height: 24px;
    transition: transform 0.2s ease;
    transform: rotate(0deg);
  }

  .humann-header__mega-trigger[aria-expanded="true"] .humann-header__chevron-icon {
    transform: rotate(180deg);
  }

  /* Right zone: icons */
  .humann-header__right {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  @media screen and (min-width: 750px) {
    .humann-header__right {
      gap: 24px;
    }
  }

  .humann-header__icon {
    display: flex;
    align-items: center;
    text-decoration: none;
    color: inherit;
    flex-shrink: 0;
  }

  .humann-header__icon img {
    width: 24px;
    height: 24px;
  }

  .humann-header__user-group {
    gap: 4px;
  }

  .humann-header__welcome-text {
    font-family: 'Stabil Grotesk', var(--font-body--family), sans-serif;
    font-weight: 500;
    font-size: 16px;
    line-height: 20px;
    color: #000000;
    white-space: nowrap;
    display: none;
  }

  @media screen and (min-width: 750px) {
    .humann-header__welcome-text {
      display: inline;
    }
  }

  /* Cart badge */
  .humann-header__cart-wrap {
    position: relative;
  }

  .humann-header__cart-badge {
    position: absolute;
    top: -6px;
    inset-inline-end: -6px;
    width: 17px;
    height: 17px;
    border-radius: 50%;
    background-color: var(--cart-badge-bg, #BC0F0F);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: '(K) Uniforma', 'Uniforma', var(--font-accent--family), sans-serif;
    font-weight: 500;
    font-size: 10px;
    line-height: 13px;
    letter-spacing: -1px;
    color: #FFFFFF;
    pointer-events: none;
  }

  /* Hamburger - mobile only */
  .humann-header__hamburger {
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    width: 24px;
    height: 24px;
    color: var(--header-text, #414141);
  }

  .humann-header__hamburger svg {
    width: 24px;
    height: 24px;
  }

  @media screen and (min-width: 750px) {
    .humann-header__hamburger {
      display: none;
    }
  }

  /* ===== MEGA-MENU (desktop only) ===== */
  .humann-header__mega-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.3);
    backdrop-filter: blur(24px);
    z-index: 98;
  }

  .humann-header__mega-overlay[aria-hidden="false"] {
    display: block;
  }

  .humann-header__mega-menu {
    display: none;
    position: absolute;
    top: 100%;
    inset-inline-start: 0;
    inset-inline-end: 0;
    z-index: 99;
    padding: 0 16px;
  }

  .humann-header__mega-menu[aria-hidden="false"] {
    display: block;
  }

  .humann-header__mega-inner {
    display: grid;
    grid-template-columns: 1fr 1fr 2fr;
    gap: 40px;
    max-width: 1408px;
    margin: 0 auto;
    background: #FFFFFF;
    border-radius: 16px;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.05);
    padding: 40px 48px;
  }

  .humann-header__mega-heading {
    font-family: '(K) Uniforma', 'Uniforma', var(--font-accent--family), sans-serif;
    font-weight: 400;
    font-size: 14px;
    line-height: 16px;
    letter-spacing: 0.75px;
    text-transform: uppercase;
    color: #9A9A9A;
    margin: 0 0 24px 0;
  }

  /* Mega Column 1: Shop Links */
  .humann-header__mega-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .humann-header__mega-link {
    font-family: 'Moderat Serif', var(--font-heading--family), serif;
    font-weight: 400;
    font-size: 28px;
    line-height: 32px;
    letter-spacing: -1px;
    color: #414141;
    text-decoration: none;
  }

  .humann-header__mega-link:hover {
    opacity: 0.7;
  }

  /* Mega Column 2: Benefits */
  .humann-header__mega-benefits {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .humann-header__mega-benefit-link {
    display: flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
  }

  .humann-header__mega-benefit-link:hover {
