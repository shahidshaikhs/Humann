<script type="module">
  if (!customElements.get('humann-header-component')) {
    class HumannHeaderComponent extends HTMLElement {
      connectedCallback() {
        this.megaTrigger = this.querySelector('[data-mega-trigger]');
        this.megaMenu = this.querySelector('[data-mega-menu]');
        this.megaOverlay = this.querySelector('[data-mega-overlay]');
        this.drawerOpenBtn = this.querySelector('[data-drawer-open]');
        this.drawerCloseBtn = this.querySelector('[data-drawer-close]');
        this.drawer = this.querySelector('[data-drawer]');
        this.drawerOverlay = this.querySelector('[data-drawer-overlay]');
        this.benefitToggle = this.querySelector('[data-benefit-toggle]');
        this.benefitSub = this.querySelector('[data-benefit-sub]');
        this.cartBadge = this.querySelector('[data-cart-badge]');
        this.cartCount = this.querySelector('[data-cart-count]');

        this.bindMegaMenu();
        this.bindDrawer();
        this.bindBenefitToggle();
        this.fetchCartCount();
      }

      bindMegaMenu() {
        if (!this.megaTrigger || !this.megaMenu) return;

        this.megaTrigger.addEventListener('click', (e) => {
          e.preventDefault();
          const isOpen = this.megaTrigger.getAttribute('aria-expanded') === 'true';
          this.toggleMegaMenu(!isOpen);
        });

        if (this.megaOverlay) {
          this.megaOverlay.addEventListener('click', () => {
            this.toggleMegaMenu(false);
          });
        }

        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && this.megaTrigger.getAttribute('aria-expanded') === 'true') {
            this.toggleMegaMenu(false);
            this.megaTrigger.focus();
          }
        });
      }

      toggleMegaMenu(open) {
        this.megaTrigger.setAttribute('aria-expanded', String(open));
        this.megaMenu.setAttribute('aria-hidden', String(!open));
        if (this.megaOverlay) {
          this.megaOverlay.setAttribute('aria-hidden', String(!open));
        }
      }

      bindDrawer() {
        if (!this.drawer) return;

        if (this.drawerOpenBtn) {
          this.drawerOpenBtn.addEventListener('click', () => {
            this.openDrawer();
          });
        }

        if (this.drawerCloseBtn) {
          this.drawerCloseBtn.addEventListener('click', () => {
            this.closeDrawer();
          });
        }

        if (this.drawerOverlay) {
          this.drawerOverlay.addEventListener('click', () => {
            this.closeDrawer();
          });
        }

        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && this.drawer.getAttribute('aria-hidden') === 'false') {
            this.closeDrawer();
          }
        });
      }

      openDrawer() {
        this.drawer.setAttribute('aria-hidden', 'false');
        if (this.drawerOverlay) {
          this.drawerOverlay.setAttribute('aria-hidden', 'false');
        }
        if (this.drawerOpenBtn) {
          this.drawerOpenBtn.setAttribute('aria-expanded', 'true');
        }
        document.body.style.overflow = 'hidden';
      }

      closeDrawer() {
        this.drawer.setAttribute('aria-hidden', 'true');
        if (this.drawerOverlay) {
          this.drawerOverlay.setAttribute('aria-hidden', 'true');
        }
        if (this.drawerOpenBtn) {
          this.drawerOpenBtn.setAttribute('aria-expanded', 'false');
        }
        document.body.style.overflow = '';
      }

      bindBenefitToggle() {
        if (!this.benefitToggle || !this.benefitSub) return;

        this.benefitToggle.addEventListener('click', () => {
          const isExpanded = this.benefitToggle.getAttribute('aria-expanded') === 'true';
          this.benefitToggle.setAttribute('aria-expanded', String(!isExpanded));
          this.benefitSub.setAttribute('aria-hidden', String(isExpanded));
        });
      }

      async fetchCartCount() {
        try {
          const res = await fetch('/cart.js', {
            credentials: 'same-origin',
            headers: { 'Content-Type': 'application/json' }
          });
          const cart = await res.json();
          if (cart.item_count > 0 && this.cartBadge && this.cartCount) {
            this.cartCount.textContent = cart.item_count;
            this.cartBadge.style.display = 'flex';
          }
        } catch (e) {
          /* fail silently */
        }
      }
    }

    customElements.define('humann-header-component', HumannHeaderComponent);
  }
</script>

