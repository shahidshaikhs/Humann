<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--page-width color-{{ section.settings.color_scheme }}"
>
  <div
    class="prefooter spacing-style"
    style="{% render 'spacing-style', settings: section.settings %}"
  >
    <div class="prefooter__content">
      <div class="prefooter__logo">
        <img
          src="{{ 'logo.svg' | asset_url }}"
          alt="{{ shop.name }}"
          width="280"
          height="48"
          loading="lazy"
        >
      </div>
      <div class="prefooter__tagline">
        <span class="prefooter__text-serif">A</span>
        <span class="prefooter__text-serif">cardiovascular</span>
        <span class="prefooter__text-serif">health</span>
        <span class="prefooter__text-serif">company</span>
        <span class="prefooter__icon prefooter__icon--chew">
          <img
            src="{{ 'chew.svg' | asset_url }}"
            alt=""
            width="28"
            height="21"
          >
        </span>
        <span class="prefooter__text-serif">focused</span>
        <span class="prefooter__text-serif">on</span>
        <span class="prefooter__text-serif">the</span>
        <span class="prefooter__text-bold">60,000</span>
        <span class="prefooter__text-bold">miles</span>
        <span class="prefooter__text-serif">of</span>
        <span class="prefooter__text-serif">your</span>
        <span class="prefooter__text-serif">cardiovascular</span>
        <span class="prefooter__text-serif">system</span>
        <span class="prefooter__icon prefooter__icon--capsule">
          <img
            src="{{ 'capsule.svg' | asset_url }}"
            alt=""
            width="44"
            height="15"
          >
        </span>
        <span class="prefooter__text-serif">fueling</span>
        <span class="prefooter__text-serif">your</span>
        <span class="prefooter__icon prefooter__icon--gummie">
          <img
            src="{{ 'gummie.svg' | asset_url }}"
            alt=""
            width="23"
            height="25"
          >
        </span>
        <span class="prefooter__text-bold">36</span>
        <span class="prefooter__text-bold">trillion</span>
        <span class="prefooter__text-bold">cells.</span>
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  .prefooter-section {
    border: 1px solid #D9D9DB;
  }

  .prefooter__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 60px;
    padding-inline: 20px;
  }

  @media screen and (min-width: 750px) {
    .prefooter__content {
      gap: 48px;
      max-width: 780px;
      margin-inline: auto;
      padding-inline: 0;
    }
  }

  .prefooter__logo {
    display: flex;
    justify-content: center;
  }

  .prefooter__logo img {
    width: 280px;
    height: 48px;
  }

  .prefooter__tagline {
    display: flex;
    flex-wrap: wrap;
    gap: 2px;
    align-items: center;
    font-size: 28px;
    line-height: 32px;
    color: var(--color-primary);
  }

  @media screen and (min-width: 750px) {
    .prefooter__tagline {
      gap: 3px;
      justify-content: center;
    }
  }

  .prefooter__text-serif {
    font-family: var(--font-heading--family);
    font-weight: 400;
    letter-spacing: -1px;
  }

  .prefooter__text-bold {
    font-family: var(--font-body--family);
    font-weight: 700;
  }

  .prefooter__icon {
    display: inline-flex;
    align-items: center;
  }

  .prefooter__icon img {
    display: block;
  }

  .prefooter__icon--chew {
    padding: 5px 2px 0 2px;
  }

  .prefooter__icon--capsule {
    padding: 10px 0 0 0;
  }

  .prefooter__icon--capsule img {
    transform: rotate(1.6deg);
  }

  .prefooter__icon--gummie {
    padding: 4px 2px 0 2px;
  }

  @media screen and (min-width: 750px) {
    .prefooter__icon--chew {
      padding: 3px 4px 0 4px;
    }

    .prefooter__icon--capsule {
      padding: 8px 4px 0 4px;
    }

    .prefooter__icon--gummie {
      padding: 2px 2px 0 2px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Prefooter",
  "class": "prefooter-section",
  "enabled_on": {
    "groups": ["footer"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 72
    }
  ]
}
{% endschema %}
